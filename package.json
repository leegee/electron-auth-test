{
  "name": "electron-secure-test",
  "version": "1.0.0",
  "description": "An Electron application with Solid and TypeScript",
  "main": "./out/main/index.js",
  "author": "example.com",
  "homepage": "https://electron-vite.org",
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "bun run typecheck:node && bun run typecheck:web",
    "start": "electron-vite preview",
    "predev": "dotenv -e .env.development -- bun generate-auth",
    "dev": "electron-vite dev",
    "generate-auth": "bun run ./scripts/generate-auth.ts",
    "prebuild": "bun generate-auth && taskkill /IM electron-secure-test.exe /F 2>NUL || exit 0",
    "build": "bun run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "dotenv -e .env.development -- bun run build && electron-builder --dir",
    "build:win": "dotenv -e .env.production -- bun run build && electron-builder --win",
    "build:mac": "dotenv -e .env.production -- electron-vite build && electron-builder --mac",
    "build:linux": "dotenv -e .env.production -- electron-vite build && electron-builder --linux"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "beercss": "^4.0.16",
    "electron-updater": "^6.3.9",
    "keytar": "^7.9.0"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/node": "^22.19.1",
    "dotenv-cli": "^11.0.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-solid": "^0.14.5",
    "prettier": "^3.7.4",
    "solid-js": "^1.9.10",
    "typescript": "^5.9.3",
    "vite": "^7.2.6",
    "vite-plugin-solid": "^2.11.10"
  },
  "build": {
    "appId": "com.electron.app",
    "productName": "electron-secure-test",
    "directories": {
      "buildResources": "build"
    },
    "files": [
      "!**/.vscode/*",
      "!src/*",
      "!electron.vite.config.{js,ts,mjs,cjs}",
      "!{.eslintcache,eslint.config.mjs,.prettierignore,.prettierrc.yaml,dev-app-update.yml,CHANGELOG.md,README.md}",
      "!{.env,.env.*,.npmrc,pnpm-lock.yaml}",
      "!{tsconfig.json,tsconfig.node.json,tsconfig.web.json}"
    ],
    "asarUnpack": [
      "resources/**"
    ],
    "win": {
      "executableName": "electron-secure-test"
    },
    "nsis": {
      "artifactName": "${name}-${version}-setup.${ext}",
      "shortcutName": "${productName}",
      "uninstallDisplayName": "${productName}",
      "createDesktopShortcut": "always"
    },
    "mac": {
      "entitlementsInherit": "build/entitlements.mac.plist",
      "extendInfo": {
        "NSCameraUsageDescription": "Application requests access to the device's camera.",
        "NSMicrophoneUsageDescription": "Application requests access to the device's microphone.",
        "NSDocumentsFolderUsageDescription": "Application requests access to the user's Documents folder.",
        "NSDownloadsFolderUsageDescription": "Application requests access to the user's Downloads folder."
      },
      "notarize": false
    },
    "dmg": {
      "artifactName": "${name}-${version}.${ext}"
    },
    "linux": {
      "target": [
        "AppImage",
        "snap",
        "deb"
      ],
      "maintainer": "electronjs.org",
      "category": "Utility"
    },
    "appImage": {
      "artifactName": "${name}-${version}.${ext}"
    },
    "npmRebuild": false,
    "publish": {
      "provider": "generic",
      "url": "https://example.com/auto-updates"
    },
    "electronDownload": {
      "mirror": "https://npmmirror.com/mirrors/electron/"
    },
    "protocols": [
      {
        "name": "MyApp Test Protocol",
        "schemes": [
          "myapp"
        ]
      }
    ]
  }
}