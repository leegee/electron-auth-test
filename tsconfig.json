{
    "compilerOptions": {
        "target": "ES2020",
        "module": "ESNext",
        "moduleResolution": "node",
        "outDir": "dist",
        "rootDir": "src",
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "esModuleInterop": true,
        "resolveJsonModule": true
    },
    "exclude": [
        "playwright.config.ts",
        // "src/renderer/**/*",
        "tests",
        "vite.config.ts"
    ]
}